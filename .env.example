# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TELEGRAM_BOT_TOKEN: The API token for your primary Telegram Bot from @BotFather.
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# --- REQUIRED FOR WA-TELEGRAM BRIDGE ---
# MONITOR_TOKEN: The Telegram bot token used for forwarding WA messages
MONITOR_TOKEN="YOUR_MONITOR_BOT_TOKEN"

# AI_TOKEN: The Telegram bot token used for the AI Assistant (Loco)
AI_TOKEN="YOUR_AI_BOT_TOKEN"

# TELEGRAM_CHAT_ID: The negative chat ID of the Telegram group where logs/AI will reside
TELEGRAM_CHAT_ID="-10000000000"
# ---------------------------------------

# DATABASE_URL: Optional for custom database path.
DATABASE_URL="file:./dev.db"
